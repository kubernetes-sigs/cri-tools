# OSX leaves these everywhere on SMB shares
._*

# OSX trash
.DS_Store

# Eclipse files
.classpath
.project
.settings/**

# Files generated by JetBrains IDEs, e.g. IntelliJ IDEA
.idea/
*.iml

# Vscode files
.vscode

# This is where the result of the go build goes
/_output*/

# Emacs save files
*~
\#*\#
.\#*

# Vim-related files
[._]*.s[a-w][a-z]
[._]s[a-w][a-z]
*.un~
Session.vim
.netrwhist

/build
release-notes.md
test/e2e/e2e.test
/crictl

CLAUDE.md
/docs/plans

# Ignore all dot-folders (for experiments with various tooling like .gemini, as well as for IDE config folders like .idea, .vscode, etc.)
.*/
# Except:
!.github/
!.skills/

